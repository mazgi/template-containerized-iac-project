# Secrets (sensitive values)
# Copy to .secrets.env for local development, or to .staging.secrets.env / .production.secrets.env for CI.
# See docs/ci.md for the env file naming convention.
# See also .example.env for non-sensitive variables.

# -------------------------------------------------------
# Terraform (sensitive)
# Register with: gh secret set --env Staging --env-file .secrets.env
# -------------------------------------------------------

# Database password for ephemeral Cloud SQL / RDS / PostgreSQL Flexible Server.
TF_VAR_database_password=change-me-database-password
